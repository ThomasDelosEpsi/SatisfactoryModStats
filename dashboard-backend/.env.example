# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ============================================================

# Port the Express app binds to locally.
# Nginx Proxy Manager forwards external traffic here.
PORT=3000

# Secret token the game server sends in the Authorization header.
# Generate a strong value: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=replace_with_a_long_random_secret

# Node environment — set to "production" on your Linux server.
NODE_ENV=production
